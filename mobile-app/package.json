{
  "name": "@ice-truck/mobile-app",
  "version": "2.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "build": "echo 'Mobile app build complete'",
    "dev": "expo start --non-interactive",
    "start": "expo start",
    "clean": "rm -rf .expo dist",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.3",
    "@react-navigation/drawer": "^7.9.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/stack": "^7.8.2",
    "@sentry/react-native": "^6.22.0",
    "expo": "~52.0.49",
    "expo-font": "~13.3.2",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-network": "~2.4.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.2.4",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~0.27.0",
    "react": "18.3.1",
    "react-native": "0.76.6",
    "react-native-gesture-handler": "~2.21.0",
    "react-native-maps": "^1.27.1",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "^5.0.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/jest-native": "^5.4.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.28",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^8.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.6",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "private": true
}
