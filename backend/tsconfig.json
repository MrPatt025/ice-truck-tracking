{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "test/**/*.{spec,test}.ts"],
  "exclude": [
    "dist",
    "coverage",
    "html/**",
    "src/_legacy/**",
    "src/**/__generated__/**",
    "test/**/__mocks__/**",
    "test/**/_*.ts"
  ]
}
