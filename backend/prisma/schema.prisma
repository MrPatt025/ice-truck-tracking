// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "sqlite"
  url          = env("DATABASE_URL") // เช่น "file:./dev.db"
  relationMode = "foreignKeys"
}

enum AlertLevel {
  INFO
  WARN
  ERROR
}

model Truck {
  id        Int       @id @default(autoincrement())
  name      String    @unique(map: "uq_truck_name")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  alerts    Alert[]
  telemetry Telemetry[]

  @@index([createdAt], map: "idx_truck_created_at")
  @@index([updatedAt], map: "idx_truck_updated_at")
}

model Alert {
  id        Int        @id @default(autoincrement())
  level     AlertLevel @default(INFO)
  message   String
  createdAt DateTime   @default(now())

  // FK + cascading ให้ความสอดคล้องของข้อมูล
  truckId Int
  truck   Truck @relation(fields: [truckId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // ดัชนีเพื่อเร่งการค้นหา/เรียงลำดับ
  @@index([truckId], map: "idx_alert_truck_id")
  @@index([createdAt], map: "idx_alert_created_at")
  @@index([truckId, createdAt], map: "idx_alert_truck_created_at")
  @@index([level, createdAt], map: "idx_alert_level_created_at")
}

model Telemetry {
  id           String   @id @default(cuid())
  truckId      Int
  truck        Truck    @relation(fields: [truckId], references: [id])
  latitude     Float
  longitude    Float
  speedKmh     Float
  cargoTempC   Float
  fuelLevelPct Float?
  batteryPct   Float?
  recordedAt   DateTime @default(now())

  @@index([truckId], map: "idx_telemetry_truck_id")
  @@index([recordedAt], map: "idx_telemetry_recorded_at")
}
