# Dashboard production environment (example)
NODE_ENV=production

# Public API base URL (must be the public origin of the backend)
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_REQUEST_ID_HEADER=x-request-id
NEXT_PUBLIC_TOMTOM_API_KEY=your-tomtom-key
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com

# Feature flags
NEXT_PUBLIC_E2E=0
NEXT_PUBLIC_THREE_HERO=1

# Sentry (client)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Disable demo mode in prod
DEMO_LOGIN=false
