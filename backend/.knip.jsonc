{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/**/*.ts",
    "prisma/**/*.ts",
    "test/**/*.ts",
    "vitest.config.ts",
  ],
  "ignore": [
    "coverage/**",
    "dist/**",
    "routes/**",
    "config/**",
    "middleware/**",
    "repositories/**",
    "*.js",
  ],
}
