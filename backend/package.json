{
  "name": "@ice-truck/backend",
  "version": "2.0.2",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=10.19.0"
  },
  "type": "commonjs",
  "sideEffects": false,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch src/generated,dist src/index.ts",
    "predev": "node -e \"process.exit(0)\"",
    "build": "tsc -p tsconfig.json",
    "prebuild": "prisma generate",
    "start": "node dist/index.js",
    "prestart": "prisma generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretypecheck": "node -e \"process.exit(0)\"",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --ext .ts --fix",
    "prelint": "node -e \"process.exit(0)\"",
    "format": "prettier --write .",
    "test": "vitest run",
    "pretest": "node scripts/prisma-safe-prepare.js",
    "test:watch": "vitest",
    "coverage": "dotenv -e .env -- vitest run --coverage",
    "precoverage": "node scripts/prisma-safe-prepare.js",
    "deadcode": "knip --config .knip.jsonc",
    "deps:audit": "depcheck --ignore-dirs=dist,coverage,prisma,_legacy --ignores=@vitest/coverage-v8,@fastify/rate-limit,@fastify/swagger-ui,pino-pretty,bcryptjs,@typescript-eslint/eslint-plugin,@typescript-eslint/parser,eslint-config-prettier,@sentry/node && ts-prune",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:validate": "prisma validate",
    "db:seed": "ts-node -P tsconfig.seed.json prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "prepare": "husky install",
    "check:all": "pnpm prisma:generate && pnpm typecheck && pnpm lint && pnpm test && pnpm deps:audit && pnpm deadcode",
    "report": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/compress": "^7.0.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/etag": "^5.0.1",
    "@fastify/helmet": "^10.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/error": "^3.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^1.10.0",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "6.18.0",
    "@sentry/node": "^10.21.0",
    "fastify": "^4.29.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "@vitest/coverage-v8": "^3.2.4",
    "c8": "^9.1.0",
    "depcheck": "^1.4.7",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.0",
    "husky": "^9.1.7",
    "knip": "^5.33.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "prisma": "6.18.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cts,mts,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "knip": {
    "ignoreDependencies": [
      "pino-pretty"
    ]
  }
}
