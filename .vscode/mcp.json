{
	"servers": {
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"my-mcp-server-a5a67ccd": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@testsprite/testsprite-mcp@latest"
			],
			"env": {
				"API_KEY": "REDACTED_TESTSPRITE_API_KEY"
			}
		},
		"com.postman/postman-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@postman/postman-mcp-server@2.8.7"
			],
			"env": {
				"POSTMAN_API_KEY": "${input:POSTMAN_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "2.8.7"
		},
		"com.figma.mcp/mcp": {
			"type": "http",
			"url": "https://mcp.figma.com/mcp",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.3"
		},
		"com.vercel/vercel-mcp": {
			"type": "http",
			"url": "https://mcp.vercel.com",
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.3"
		},
		"io.github.SonarSource/sonarqube-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"SONARQUBE_TOKEN",
				"-e",
				"SONARQUBE_ORG",
				"-e",
				"SONARQUBE_URL",
				"docker.io/mcp/sonarqube:latest"
			],
			"env": {
				"SONARQUBE_TOKEN": "${input:SONARQUBE_TOKEN}",
				"SONARQUBE_ORG": "${input:SONARQUBE_ORG}",
				"SONARQUBE_URL": "${input:SONARQUBE_URL}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.12.0"
		},
		"io.github.vercel/next-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"next-devtools-mcp@0.3.6"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.3.6"
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.0.4"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.4"
		},
		"com.stackoverflow.mcp/mcp": {
			"type": "http",
			"url": "https://mcp.stackoverflow.com",
			"gallery": "https://api.mcp.github.com",
			"version": "1.1.3"
		},
		"io.github.ChromeDevTools/chrome-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--registry",
				"https://registry.npmjs.org",
				"chrome-devtools-mcp@0.25.0"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.25.0"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp@0.0.1a4"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		}
	},
	"inputs": [
		{
			"id": "SONARQUBE_TOKEN",
			"type": "promptString",
			"description": "Your SonarQube USER token",
			"password": true
		},
		{
			"id": "SONARQUBE_ORG",
			"type": "promptString",
			"description": "Your SonarQube Cloud organization key (if using SonarQube Cloud)",
			"password": true
		},
		{
			"id": "SONARQUBE_URL",
			"type": "promptString",
			"description": "Your SonarQube Server URL (if using SonarQube Server)",
			"password": true
		},
		{
			"id": "MAPBOX_ACCESS_TOKEN",
			"type": "promptString",
			"description": "Your Mapbox access token",
			"password": true
		},
		{
			"id": "POSTMAN_API_KEY",
			"type": "promptString",
			"description": "A valid Postman API key.",
			"password": true
		},
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}