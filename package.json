{
  "name": "ice-truck-tracking-monorepo",
  "version": "2.0.0",
  "description": "Professional Ice Truck Tracking System — Enterprise Monorepo",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20 <21",
    "pnpm": ">=9"
  },
  "workspaces": [
    "backend",
    "dashboard",
    "mobile-app",
    "sdk/edge",
    "sdk/mobile"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky install",
    "dev": "turbo run dev --parallel --continue",
    "build": "turbo run build",
    "build:all": "turbo run build --force",
    "start": "turbo run start",
    "test": "turbo run test --continue",
    "test:unit": "turbo run test:unit --continue",
    "test:integration": "turbo run test:integration --continue",
    "test:e2e": "playwright test",
    "test:coverage": "turbo run coverage --continue",
    "test:mutation": "turbo run test:mutation --continue",
    "type-check": "turbo run type-check --continue",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings=0",
    "format": "prettier -w .",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css,scss,less}\"",
    "fix": "pnpm format && pnpm lint:fix",
    "check": "pnpm format:check && pnpm lint:ci && pnpm type-check && pnpm test",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "clean:all": "turbo run clean && rimraf node_modules .turbo backend/node_modules dashboard/node_modules mobile-app/node_modules sdk/edge/node_modules sdk/mobile/node_modules",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v --remove-orphans && docker system prune -f",
    "deploy": "pnpm build && pnpm docker:build && pnpm docker:up",
    "deploy:staging": "pnpm build && docker compose -f docker-compose.staging.yml up -d",
    "deploy:production": "pnpm build && docker compose -f docker-compose.production.yml up -d",
    "deps:update": "npx npm-check-updates -u && pnpm install",
    "deps:dedupe": "pnpm dedupe",
    "deps:upgrade": "pnpm -w exec taze -w --write",
    "commitlint": "commitlint --from=HEAD~1",
    "release": "semantic-release",
    "changeset": "changeset",
    "changeset:init": "changeset init",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "security:audit:npm": "npm audit --audit-level=high || true",
    "security:audit": "node security-audit.js",
    "security:fix": "npm audit fix || true",
    "security:snyk": "snyk test || true",
    "snyk:auth": "snyk auth",
    "analyze:frontend": "cd dashboard && pnpm run analyze || true",
    "load:test": "node load-test.js",
    "db:cleanup": "node cleanup-orphaned-data.js",
    "validate": "pnpm -F backend typecheck && pnpm -F backend test && pnpm -F backend coverage && pnpm -F backend deadcode && pnpm -F backend deps:audit",
    "tool:eslint": "pnpm -w exec eslint",
    "tool:prettier": "pnpm -w exec prettier",
    "tool:tsc": "pnpm -w exec tsc",
    "tool:oxlint": "pnpm -w exec oxlint",
    "tool:cspell": "pnpm -w exec cspell",
    "tool:secretlint": "pnpm -w exec secretlint \"**/*\"",
    "gen:types": "openapi-typescript backend/src/docs/openapi.yaml -o dashboard/src/types/api.d.ts",
    "gen:client": "orval --config orval.config.cjs",
    "gen:api": "pnpm run gen:types && pnpm run gen:client",
    "gen:api:watch": "orval --config orval.config.cjs --watch",
    "storybook": "pnpm -F dashboard storybook dev -p 6006",
    "a11y": "turbo run a11y --continue",
    "a11y:scan": "axe --chrome --disable-exit http://localhost:3000",
    "unused:exports": "ts-prune",
    "unused:files": "knip",
    "unused:deps": "depcheck",
    "analyze:bundle": "cross-env ANALYZE=true pnpm -F dashboard build",
    "check:all": "pnpm format:check && pnpm lint:ci && pnpm type-check && pnpm build && pnpm test",
    "smoke": "node ./scripts/smoke-login.mjs"
  },
  "devDependencies": {
    "@axe-core/cli": "4.11.0",
    "@axe-core/playwright": "^4.11.0",
    "@biomejs/biome": "^2.3.2",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.38.0",
    "@ianvs/prettier-plugin-sort-imports": "4.7.0",
    "@next/bundle-analyzer": "^15.5.6",
    "@playwright/test": "^1.56.1",
    "@size-limit/preset-app": "^11.2.0",
    "@t3-oss/env-nextjs": "0.13.8",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^10.1.0",
    "cspell": "^9.2.2",
    "cypress-axe": "^1.7.0",
    "depcheck": "^1.4.7",
    "envalid": "^8.1.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-storybook": "9.1.16",
    "eslint-plugin-tailwindcss": "3.18.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.4.0",
    "happy-dom": "^20.0.10",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "knip": "^5.66.4",
    "lint-staged": "^16.2.6",
    "msw": "^2.11.6",
    "openapi-typescript": "^7.10.1",
    "orval": "6.25.0",
    "oxlint": "^1.25.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "0.7.1",
    "rimraf": "^6.0.1",
    "secretlint": "^11.2.5",
    "semantic-release": "^24.2.9",
    "snyk": "^1.1300.2",
    "taze": "^19.9.0",
    "ts-prune": "^0.10.3",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.0",
    "zod": "^4.1.12"
  },
  "keywords": [
    "monorepo",
    "ice-truck",
    "tracking",
    "turborepo",
    "enterprise",
    "typescript",
    "react",
    "node.js"
  ],
  "author": "Mr. Pattanakorn (MrPatt025)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrPatt025/ice-truck-tracking.git"
  },
  "bugs": {
    "url": "https://github.com/MrPatt025/ice-truck-tracking/issues"
  },
  "homepage": "https://github.com/MrPatt025/ice-truck-tracking#readme",
  "pnpm": {
    "overrides": {
      "next": "15.5.6",
      "@fastify/cors": "^9.0.1",
      "@fastify/helmet": "^10.1.1",
      "@fastify/websocket": "^8.3.1",
      "@prisma/client": "^6.18.0",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "fastify-type-provider-zod": "^2.1.0",
      "prisma": "^6.18.0"
    },
    "onlyBuiltDependencies": [
      "@scarf/scarf",
      "@tailwindcss/oxide",
      "bcrypt",
      "sqlite3"
    ],
    "ignoredBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "core-js",
      "cypress",
      "detox",
      "dtrace-provider",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "snyk",
      "unrs-resolver"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "react",
        "react-dom"
      ],
      "ignoreMissing": [
        "react",
        "react-dom",
        "@react-three/fiber"
      ]
    },
    "packageExtensions": {
      "@react-three/drei@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20",
          "@react-three/fiber": ">=8"
        }
      },
      "react-composer@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@react-spring/core@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@react-spring/animated@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@react-spring/shared@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@react-spring/three@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "leva@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      },
      "@radix-ui/react-portal@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      },
      "@radix-ui/react-tooltip@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      },
      "@radix-ui/react-presence@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      },
      "@radix-ui/react-primitive@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      },
      "@radix-ui/react-id@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@radix-ui/react-use-layout-effect@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@radix-ui/react-context@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@radix-ui/react-visually-hidden@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      },
      "@radix-ui/react-dismissable-layer@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      },
      "@radix-ui/react-use-escape-keydown@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@radix-ui/react-popper@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      },
      "@radix-ui/react-use-size@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@radix-ui/react-use-rect@*": {
        "peerDependencies": {
          "react": ">=18 <20"
        }
      },
      "@radix-ui/react-arrow@*": {
        "peerDependencies": {
          "react": ">=18 <20",
          "react-dom": ">=18 <20"
        }
      }
    }
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "trailingComma": "all",
    "singleQuote": true,
    "semi": true
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css,scss,less}": [
      "prettier -w"
    ]
  },
  "volta": {
    "node": "20.19.4",
    "pnpm": "10.20.0"
  }
}
