{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "types": [
            "node"
        ]
    },
    "include": [
        "e2e/**/*.cy.ts",
        "e2e/**/*.cy.tsx",
        "support/**/*.ts",
        "support/**/*.d.ts"
    ]
}
