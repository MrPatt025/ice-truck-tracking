# Web Application Environment Variables

# ── API Configuration ──────────────────────────────────────
# Backend API base URL (without /api/v1 — will be appended automatically)
# 
# Examples:
#   http://localhost:5000 → calls http://localhost:5000/api/v1/auth/login
#   https://api.yourdomain.com → calls https://api.yourdomain.com/api/v1/auth/register
#
NEXT_PUBLIC_API_URL=http://localhost:5000

# WebSocket URL for real-time updates (must match API backend)
# Development: ws://localhost:5000
# Production: wss://api.yourdomain.com
#
NEXT_PUBLIC_WS_URL=ws://localhost:5000

# ── Application Settings ────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Ice Truck Tracking
NEXT_PUBLIC_APP_VERSION=2.0.0

# ── Map Configuration ──────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# ── Feature Flags ──────────────────────────────────────────
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# ── Development ────────────────────────────────────────────
NODE_ENV=development
