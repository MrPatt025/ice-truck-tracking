# Monorepo (Node.js / Next.js / Express)
# ใช้ pnpm เป็นหลัก: อย่าลบ pnpm-lock.yaml ออกจาก repo

# ─────────────────────────
# Dependencies
# ─────────────────────────
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
yarn.lock
package-lock.json
bun.lockb

# ─────────────────────────
# Build outputs
# ─────────────────────────
**/dist/
**/build/
**/.next/
**/.turbo/
**/out/
.expo/
web-build/
storybook-static/

# ─────────────────────────
# Caches & Temp
# ─────────────────────────
**/.cache/
**/.parcel-cache/
**/.eslintcache
**/.stylelintcache
**/.vite
**/.tsbuildinfo
**/tmp/
**/temp/
.cache-loader/

# ─────────────────────────
# Test artifacts
# ─────────────────────────
**/coverage/
**/test-results/
**/.nyc_output/
playwright-report/
playwright/.auth/
cypress/screenshots/
cypress/videos/

# ─────────────────────────
# Runtime / PIDs
# ─────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ─────────────────────────
# Logs
# ─────────────────────────
logs/
*.log
*.log.*

# ─────────────────────────
# Databases (local/dev)
# ─────────────────────────
*.sqlite
*.sqlite3
*.db

# ─────────────────────────
# Env files (ตัวอย่างเท่านั้นที่ควรอยู่ใน repo)
# ─────────────────────────
**/.env
**/.env.*        # e.g. .env.local, .env.production, ...
!**/.env.example # ยกเว้นไฟล์ตัวอย่าง

# ─────────────────────────
# OS junk
# ─────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─────────────────────────
# Editors / IDE
# ─────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.iml

# ─────────────────────────
# Hosting / CI
# ─────────────────────────
.vercel/

# ─────────────────────────
# Docker
# ─────────────────────────
# (อย่าลง .dockerignore / Dockerfile ใน .gitignore เพื่อให้คอมมิตขึ้น repo)
docker-data/

# ─────────────────────────
# Terraform
# ─────────────────────────
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# ─────────────────────────
# Kubernetes
# ─────────────────────────
*.kubeconfig

# ─────────────────────────
# Monitoring / Grafana
# ─────────────────────────
grafana-storage/

# ─────────────────────────
# Security / Certificates (local only)
# ─────────────────────────
*.pem
*.key
*.crt
ssl/

# ─────────────────────────
# Node / Tooling miscellany
# ─────────────────────────
.npm/
.pnp.*
.node_repl_history

coverage/

*storybook.log
