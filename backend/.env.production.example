# Backend production environment (example)
NODE_ENV=production
PORT=5000

# JWT secret for signing access tokens (use a strong random value)
JWT_SECRET=replace-with-strong-secret

# Restrict CORS to the deployed dashboard origin(s)
# Comma-separated list or single URL; do NOT leave '*' in production.
CORS_ORIGINS=https://dashboard.your-domain.com

# Require auth for protected endpoints (alerts, etc.)
REQUIRE_AUTH=true

# Demo features should be disabled in prod
DEMO_REGISTER=false
DEMO_LOGIN=false

# Optional admin backdoor for break-glass (remove in real prod)
# ADMIN_USER=
# ADMIN_PASS=

# Database connection
# DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public

# Telemetry / observability (optional)
# SENTRY_DSN=
