{
  "name": "@ice-truck/dashboard",
  "version": "1.0.1",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20 <21",
    "pnpm": ">=10.19.0 <=10.20.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "prebuild": "",
    "build": "next build",
    "start": "next start -p 3000",
    "clean": "rimraf .next dist coverage storybook-static",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:a11y": "eslint . --max-warnings=0",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests",
    "test:a11y": "jest --selectProjects a11y",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:a11y": "playwright test e2e/a11y/axe-smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "start-storybook": "storybook dev -p 6006 --ci",
    "a11y": "start-server-and-test start-storybook http://127.0.0.1:6006 \"test-storybook --ci --url http://127.0.0.1:6006\"",
    "md:lint": "markdownlint '**/*.md' --ignore node_modules --ignore .next",
    "analyze": "cross-env ANALYZE=true next build",
    "size": "size-limit",
    "prepare": "husky install",
    "gen:openapi": "openapi-typescript ../backend/openapi.json -o src/types/api.d.ts",
    "gen:client": "orval --config orval.config.cjs",
    "gen:api": "pnpm gen:openapi && pnpm gen:client",
    "ci": "pnpm lint:a11y && pnpm type-check && pnpm test && pnpm build",
    "check:all": "pnpm type-check && pnpm lint && pnpm test && pnpm size"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/fiber": "^9.4.0",
    "@sentry/browser": "^8.28.0",
    "@t3-oss/env-nextjs": "0.13.8",
    "@tanstack/react-query": "^5.90.5",
    "@tomtom-international/web-sdk-maps": "6.25.0",
    "@turf/turf": "^7.2.0",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.65.0",
    "react-i18next": "^16.0.1",
    "recharts": "^3.2.1",
    "socket.io-client": "^4.8.1",
    "styled-jsx": "^5.1.7",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "three": "^0.180.0",
    "unleash-proxy-client": "^3.7.8",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@chromatic-com/storybook": "^4.1.1",
    "@next/bundle-analyzer": "^16.0.1",
    "@next/eslint-plugin-next": "16.0.1",
    "@playwright/test": "^1.56.1",
    "@size-limit/preset-app": "^11.2.0",
    "@storybook/addon-a11y": "^9.1.16",
    "@storybook/addon-docs": "9.1.16",
    "@storybook/addon-onboarding": "9.1.16",
    "@storybook/nextjs-vite": "^9.1.16",
    "@storybook/react": "^9.1.16",
    "@storybook/test-runner": "^0.21.3",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.180.0",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.11.0",
    "cross-env": "^10.1.0",
    "cypress": "^15.4.0",
    "cypress-axe": "^1.7.0",
    "cypress-plugin-tab": "^1.0.5",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.6",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-storybook": "9.1.16",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.2.6",
    "markdownlint-cli": "0.45.0",
    "msw": "^2.11.6",
    "next": "16.0.1",
    "openapi-typescript": "^7.10.1",
    "playwright": "^1.56.1",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "react-test-renderer": "^19.2.0",
    "rimraf": "^6.0.1",
    "size-limit": "^11.2.0",
    "start-server-and-test": "^2.0.3",
    "storybook": "9.1.16",
    "tailwindcss": "^4.1",
    "typescript": "^5.7",
    "vite": "^5.4.11"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "size-limit": [
    {
      "name": "core app bundle",
      "path": [
        ".next/static/chunks/**/*.js"
      ],
      "limit": "3000 kB"
    }
  ]
}
