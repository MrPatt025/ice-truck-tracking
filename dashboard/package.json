{
  "name": "@ice-truck/dashboard",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "clean": "rm -rf .next dist",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='__tests__' --passWithNoTests",
    "test:e2e": "npx playwright test --config=playwright.light.config.ts",
    "test:e2e:light": "npx playwright test --config=playwright.light.config.ts",
    "test:e2e:gpu": "npx playwright test --config=playwright.gpu.config.ts",
    "test:e2e:a11y": "npx playwright test --config=playwright.a11y.config.ts",
    "test:e2e:visual": "npx playwright test --config=playwright.visual.config.ts",
    "test:e2e:visual:update": "npx playwright test --config=playwright.visual.config.ts --update-snapshots",
    "test:e2e:ui": "npx playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11",
    "@headlessui/react": "^2.2.9",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/fiber": "^9.5.0",
    "@react-three/offscreen": "^0.0.8",
    "@react-three/postprocessing": "^3.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.576.0",
    "mapbox-gl": "^3.19.0",
    "next": "^15.5.14",
    "postprocessing": "^6.39.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.14",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/nextjs": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^22.19.13",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.27",
    "cypress": "^15.13.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.14",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react-test-renderer": "^18.3.1",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
