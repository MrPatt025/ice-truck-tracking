{
  "name": "ice-truck-tracking",
  "version": "2.0.0",
  "description": "Professional Ice Truck Tracking System - Enterprise Monorepo",
  "private": true,
  "scripts": {
    "preinstall": "only-allow pnpm",
    "build": "npx turbo run build",
    "build:all": "turbo run build --force",
    "test": "jest --config ./jest.config.js --passWithNoTests",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test:coverage",
    "test:mutation": "npx turbo run test:mutation",
    "test:all": "turbo run test:unit test:integration test:e2e",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "type-check": "tsc --noEmit",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "clean:all": "turbo run clean && rimraf node_modules .turbo backend/node_modules dashboard/node_modules mobile-app/node_modules sdk/edge/node_modules sdk/mobile/node_modules",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans && docker system prune -f",
    "deploy": "pnpm run build && pnpm run docker:build && pnpm run docker:up",
    "deploy:staging": "pnpm run build && docker-compose -f docker-compose.staging.yml up -d",
    "deploy:production": "pnpm run build && docker-compose -f docker-compose.production.yml up -d",
    "security:audit": "pnpm audit --audit-level=high && turbo run security:audit",
    "security:fix": "pnpm audit fix && turbo run security:fix",
    "deps:update": "npx npm-check-updates -u && pnpm install",
    "deps:dedupe": "pnpm dedupe",
    "health:check": "node scripts/health-check.js",
    "setup": "pnpm install && turbo run build && npm run docker:up",
    "prepare": "husky",
    "bootstrap": "pnpm install && turbo run build && turbo run lint && turbo run test",
    "commit": "cz",
    "commitlint": "commitlint --from=HEAD~1",
    "release": "npx semantic-release",
    "security:snyk": "npx snyk test",
    "analyze:frontend": "cd dashboard && pnpm run analyze",
    "snyk:auth": "npx snyk auth"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "commitizen": "^4.3.1",
    "conventional-changelog-cli": "^5.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lucide-react": "^1.11.0",
    "npm-check-updates": "^22.0.1",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "snyk": "^1.1304.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "keywords": [
    "monorepo",
    "ice-truck",
    "tracking",
    "turborepo",
    "enterprise",
    "typescript",
    "react",
    "node.js"
  ],
  "author": "Ice Truck Tracking Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ice-truck-tracking/monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/ice-truck-tracking/monorepo/issues"
  },
  "homepage": "https://github.com/ice-truck-tracking/monorepo#readme",
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/github",
      "@semantic-release/npm"
    ]
  },
  "pnpm": {
    "overrides": {
      "pify": "4.0.1",
      "axios": "^1.13.5",
      "fast-xml-parser": "^5.5.7",
      "handlebars": "^4.7.9",
      "handlebars@<4.7.9": "^4.7.9",
      "minimatch@<3.1.3": "^3.1.3",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "glob@<10.3.0": "^10.3.0",
      "glob@>=10.2.0 <10.5.0": "^10.5.0",
      "js-yaml@<4.1.0": "^4.1.0",
      "@xmldom/xmldom": "^0.8.12",
      "@xmldom/xmldom@<0.8.12": "^0.8.12",
      "lodash@<4.18.0": "^4.18.0",
      "lodash": "^4.18.0",
      "path-to-regexp@<0.1.13": "^0.1.13",
      "path-to-regexp@>=8.0.0 <8.4.0": "^8.4.0",
      "qs@<6.11.2": "^6.11.2",
      "semver@<7.5.4": "^7.5.4",
      "node-forge": "^1.4.0",
      "node-forge@<1.4.0": "^1.4.0",
      "tar@<6.2.1": "^6.2.1",
      "tar@<7.5.11": "^7.5.11",
      "tar@>=7.0.0 <7.5.11": "^7.5.11",
      "undici@<5.28.4": "^5.28.4",
      "undici": "^6.24.0",
      "undici@<6.24.0": "^6.24.0",
      "undici@>=6.0.0 <6.24.0": "^6.24.0",
      "picomatch": "^4.0.4",
      "picomatch@<4.0.4": "^4.0.4",
      "serialize-javascript": "^7.0.3",
      "underscore": "^1.13.8",
      "flatted": "^3.4.2",
      "socket.io-parser": "^4.2.6",
      "commitizen>glob": "^10.5.0",
      "react-native>glob": "^10.5.0",
      "@conventional-changelog/git-client@<2.0.0": ">=2.0.0",
      "tmp@<=0.2.3": ">=0.2.4",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "qs@<6.14.1": ">=6.14.1",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "hono@<4.12.12": ">=4.12.12",
      "hono@>=4.0.0 <=4.12.11": ">=4.12.12",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "axios@<1.15.0": ">=1.15.0",
      "next@>=13.0.0 <15.5.15": ">=15.5.15",
      "follow-redirects@<=1.15.11": ">=1.16.0",
      "axios@>=1.0.0 <1.15.0": ">=1.15.0",
      "protobufjs@<7.5.5": ">=7.5.5",
      "protobufjs": ">=7.5.5",
      "protocol-buffers-schema": ">=3.6.1"
    },
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "@sentry/cli",
      "dtrace-provider",
      "sharp",
      "snyk",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "core-js-pure",
