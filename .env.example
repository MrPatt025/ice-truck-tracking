# ───────────────
# Core / Backend
# ───────────────
NODE_ENV=development            # เปลี่ยนเป็น production ตอน deploy
HOST=0.0.0.0
PORT=5000

# ───────────────
# Security
# ───────────────
JWT_SECRET=CHANGE_ME_SUPER_SECRET_KEY
SALT_ROUNDS=10                  # 10–12 สำหรับ prod
CORS_ORIGIN=http://localhost:3000

# Rate limit (ปิดใน dev ได้)
DISABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=60000      # 1 นาที
RATE_LIMIT_MAX_REQUESTS=600     # dev สูงหน่อย

# Feature flags / Dev toggles
FEATURE_FLAGS_ENABLED=true
USE_FAKE_DB=true

# ───────────────
# Database / Cache
# ───────────────
# ใช้ SQLite ทันทีใน dev; เปลี่ยนเป็น Postgres/MySQL ตามต้องการตอน prod
DB_URL=./database.sqlite
REDIS_URL=redis://localhost:6379

# ───────────────
# Dashboard (Next.js)
# ───────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000
NEXT_PUBLIC_MAPBOX_TOKEN=YOUR_MAPBOX_TOKEN

# Disable Next telemetry (เลือกได้)
NEXT_TELEMETRY_DISABLED=1

# สำหรับ next.config.js ถ้าคุณอ่านค่า env นี้ไปแตกเป็น array (CSV)
NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3000,http://192.168.56.1:3000

# ───────────────
# Notifications (ตัวเลือก)
# ───────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SLACK_WEBHOOK=
LINE_TOKEN=

# ───────────────
# Email (ตัวเลือก)
# ───────────────
EMAIL_SERVICE_URL=
EMAIL_SERVICE_TOKEN=
FROM_EMAIL=noreply@yourdomain.com

# ───────────────
# Cloud / Deploy (ตัวเลือก)
# ───────────────
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Docker Registry (สำหรับ CI/CD push image)
DOCKER_USERNAME=
DOCKER_PASSWORD=

# ───────────────
# Monitoring (ตัวเลือก)
# ───────────────
GF_SECURITY_ADMIN_PASSWORD=admin123

# ───────────────
# Logging
# ───────────────
LOG_LEVEL=info
