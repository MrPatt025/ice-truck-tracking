{
  "name": "@ice-truck/mcp-server",
  "version": "1.0.0",
  "private": true,
  "description": "Model Context Protocol server for Ice Truck Tracking backend operations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ice-truck-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "typescript": "^5.9.3"
  }
}
