{
  "name": "@ice-truck/backend",
  "version": "2.0.0",
  "description": "Professional Ice Truck Tracking System - Backend API",
  "main": "index.js",
  "scripts": {
    "build": "echo 'Backend build complete'",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --detectOpenHandles --passWithNoTests",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration --runInBand",
    "test:containers": "jest --config ./jest.testcontainers.config.js tests/integration/database.testcontainers.test.js --runInBand --testTimeout=120000",
    "test:watch": "jest --watch",
    "lint": "eslint . --fix",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "clean": "rm -rf dist coverage",
    "db:migrate": "psql $DATABASE_URL -f database/migrations/001_init.sql",
    "setup": "node src/config/database.js",
    "docker:build": "docker build -t ice-truck-backend .",
    "docker:run": "docker run -p 5000:5000 ice-truck-backend"
  },
  "keywords": [
    "ice-truck",
    "tracking",
    "gps",
    "logistics",
    "api"
  ],
  "author": "Ice Truck Tracking Team",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mqtt": "^5.15.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@faker-js/faker": "^9.9.0",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "testcontainers": "^10.18.0"
  }
}
