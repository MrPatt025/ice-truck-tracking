# ──────────────────────────────────────────────────────────────
# Ice Truck Tracking System — Environment Configuration
# Copy to .env and fill in production values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Application ─────────────────────────────────────────────
NODE_ENV=production
PORT=5000
APP_NAME=ice-truck-tracking
APP_VERSION=2.1.0

# ── Local Docker Compose (required for `docker-compose.yml`) ─
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_POSTGRES_PASSWORD
POSTGRES_DB=ice_tracking
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_LOCAL_GRAFANA_PASSWORD

# ── Security / Authentication ───────────────────────────────
# REQUIRED — Generate a strong random secret (min 32 chars):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_LOCAL_JWT_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SALT_ROUNDS=12

# OAuth2 / OIDC (Keycloak)
OIDC_ISSUER=https://auth.yourdomain.com/realms/ice-truck
OIDC_CLIENT_ID=ice-truck-api
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=ice-truck-api

# ── Database (PostgreSQL + TimescaleDB) ─────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ice_tracking
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_SSL=true

# PgBouncer (Connection Pooling)
PGBOUNCER_URL=postgresql://postgres:CHANGE_ME@localhost:6432/ice_tracking
PGBOUNCER_POOL_MODE=transaction

# Read Replica
DB_REPLICA_URL=postgresql://reader:CHANGE_ME@replica.db.internal:5432/ice_tracking

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_KEY_PREFIX=ict:
REDIS_DEFAULT_TTL=300

# ── MQTT (Eclipse Mosquitto) ───────────────────────────────
MQTT_BROKER_URL=mqtts://mosquitto:8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=ice-truck-backend
MQTT_TLS_CA=/certs/ca.crt
MQTT_TLS_CERT=/certs/client.crt
MQTT_TLS_KEY=/certs/client.key

# ── Message Queue (Apache Kafka) ───────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=ice-truck-api
KAFKA_GROUP_ID=ice-truck-consumers
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ── API Gateway (Kong) ─────────────────────────────────────
KONG_ADMIN_URL=http://kong:8001
KONG_PROXY_URL=http://kong:8000

# ── Client URLs ─────────────────────────────────────────────
CLIENT_URL=https://dashboard.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=https://dashboard.yourdomain.com,https://mobile.yourdomain.com
CORS_CREDENTIALS=true

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=20

# ── Notification Services ──────────────────────────────────
# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Slack
SLACK_WEBHOOK_URL=

# LINE Notify
LINE_NOTIFY_TOKEN=

# Email (SMTP)
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ── AWS (Production) ───────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=ice-truck-assets

# ── Docker Registry ────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/pattanakorn025
DOCKER_USERNAME=
DOCKER_PASSWORD=

# ── Monitoring / Observability ─────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3001
LOKI_URL=http://loki:3100
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# ── SonarQube / SonarCloud (CI + MCP tooling) ─────────────
SONAR_HOST_URL=https://sonarcloud.io
SONAR_TOKEN=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=ice-truck-api

# ── Feature Flags (Unleash) ────────────────────────────────
UNLEASH_URL=http://unleash:4242/api
UNLEASH_API_TOKEN=
UNLEASH_APP_NAME=ice-truck
UNLEASH_ENVIRONMENT=production

# ── Secrets Management (HashiCorp Vault) ───────────────────
VAULT_ADDR=https://vault.yourdomain.com
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/data/ice-truck

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── Health Check ────────────────────────────────────────────
HEALTH_CHECK_TIMEOUT=5000

# ── Performance ─────────────────────────────────────────────
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
HTTP2_ENABLED=true

# ── Data Warehouse (ClickHouse) ────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=ice_truck_analytics

# ── AI / ML Pipeline ───────────────────────────────────────
AI_ANOMALY_DETECTION_URL=http://ml-service:8080/predict
AI_MODEL_VERSION=v1
