#############################################
# Backend Environment Example (Development) #
#############################################

# Server
PORT=5000
NODE_ENV=development

# CORS (comma-separated or single URL)
# Do not use '*' with credentials. Keep local dashboard URLs during dev.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# WebSocket toggle (optional)
ENABLE_WS=false

# Request ID header name to trust/emit
REQUEST_ID_HEADER=x-request-id

# JWT Secret (use a strong random value in real envs)
JWT_SECRET=your_jwt_secret_key_here_123456

# Database (if applicable; or use Prisma DATABASE_URL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ice_trackings
# DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public

# External API base (optional; used by legacy HTML or utilities)
API_BASE_URL=https://unpunished-andree-coeternally.ngrok-free.dev

# Observability (optional)
SENTRY_DSN=

# Demo toggles (dev only)
DEMO_REGISTER=true
DEMO_LOGIN=true
