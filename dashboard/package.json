{
  "name": "@ice-truck/dashboard",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "clean": "rm -rf .next dist",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "jest --ci --coverage --passWithNoTests",
    "test:watch": "jest --ci --coverage --passWithNoTests",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='__tests__' --passWithNoTests",
    "test:e2e": "npx playwright test --config=playwright.light.config.ts",
    "test:e2e:light": "npx playwright test --config=playwright.light.config.ts",
    "test:e2e:gpu": "npx playwright test --config=playwright.gpu.config.ts",
    "test:e2e:a11y": "npx playwright test --config=playwright.a11y.config.ts",
    "test:e2e:visual": "npx playwright test --config=playwright.visual.config.ts",
    "test:e2e:visual:update": "npx playwright test --config=playwright.visual.config.ts --update-snapshots",
    "test:e2e:ui": "npx playwright test --ui",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "^9.3.1",
    "@deck.gl/core": "^9.3.1",
    "@deck.gl/layers": "^9.3.1",
    "@deck.gl/mapbox": "^9.3.1",
    "@headlessui/react": "^2.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/fiber": "^9.6.0",
    "@react-three/offscreen": "^0.0.8",
    "@react-three/postprocessing": "^3.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "mapbox-gl": "^3.22.0",
    "next": "^16.2.4",
    "next-pwa": "^5.6.0",
    "postprocessing": "^6.39.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.9",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "autoprefixer": "^10.5.0",
    "cypress": "^15.14.1",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
