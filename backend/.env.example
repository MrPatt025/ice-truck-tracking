# ─── Ice Truck Tracking — Backend Environment ───────────────

NODE_ENV=development
PORT=5000

# ─── API Endpoints ──────────────────────────────────────────
# Application endpoints: http://localhost:5000/api/v1/{endpoint}
#   POST /api/v1/auth/login
#   POST /api/v1/auth/register
#   GET /api/v1/trucks (protected)
#   POST /api/v1/tracking (protected)
# 
# Metrics endpoint: http://localhost:5000/metrics (Prometheus)
# Health check: http://localhost:5000/api/v1/health

# ─── PostgreSQL + TimescaleDB ────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ice_tracking
DB_POOL_MAX=20

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MQTT (Eclipse Mosquitto) ────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─── Security ────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
SALT_ROUNDS=12

# ─── CORS ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── SonarQube / SonarCloud (CI + MCP tooling) ──────────────
SONAR_HOST_URL=https://sonarcloud.io
SONAR_TOKEN=

# ─── Dev / Test ──────────────────────────────────────────────
USE_FAKE_DB=false
