{
  "name": "ice-truck-tracking",
  "version": "2.0.0",
  "description": "Professional Ice Truck Tracking System - Enterprise Monorepo",
  "private": true,
  "scripts": {
    "preinstall": "only-allow pnpm",
    "build": "pnpm exec turbo run build",
    "build:all": "turbo run build --force",
    "test": "pnpm --filter @ice-truck/backend --filter @ice-truck/dashboard test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test:coverage",
    "test:mutation": "npx turbo run test:mutation",
    "test:k6": "node -e \"require('fs').mkdirSync('reports', { recursive: true })\" && k6 run tests/k6/load-test.js",
    "test:all": "turbo run test:unit test:integration test:e2e",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "type-check": "tsc --noEmit",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "clean:all": "turbo run clean && rimraf node_modules .turbo backend/node_modules dashboard/node_modules mobile-app/node_modules sdk/edge/node_modules sdk/mobile/node_modules",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans && docker system prune -f",
    "deploy": "pnpm run build && pnpm run docker:build && pnpm run docker:up",
    "deploy:staging": "pnpm run build && docker-compose -f docker-compose.yml up -d",
    "deploy:production": "pnpm run build && docker-compose -f docker-compose.yml up -d",
    "security:audit": "pnpm audit --audit-level=high && turbo run security:audit",
    "security:fix": "pnpm audit fix && turbo run security:fix",
    "deps:update": "pnpm dlx npm-check-updates -u && pnpm install",
    "deps:dedupe": "pnpm dedupe",
    "health:check": "node scripts/health-check.js",
    "setup": "pnpm install && turbo run build && npm run docker:up",
    "prepare": "husky",
    "bootstrap": "pnpm install && turbo run build && turbo run lint && turbo run test",
    "commit": "cz",
    "commitlint": "commitlint --from=HEAD~1",
    "release": "npx semantic-release",
    "security:snyk": "npx snyk test",
    "analyze:frontend": "pnpm --dir dashboard run analyze",
    "snyk:auth": "npx snyk auth"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "commitizen": "^4.3.1",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lucide-react": "^1.11.0",
    "npm-check-updates": "^22.0.1",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "snyk": "^1.1304.0",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "keywords": [
    "monorepo",
    "ice-truck",
    "tracking",
    "turborepo",
    "enterprise",
    "typescript",
    "react",
    "node.js"
  ],
  "author": "Ice Truck Tracking Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ice-truck-tracking/monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/ice-truck-tracking/monorepo/issues"
  },
  "homepage": "https://github.com/ice-truck-tracking/monorepo#readme",
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/github",
      "@semantic-release/npm"
    ]
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2"
  }
}
