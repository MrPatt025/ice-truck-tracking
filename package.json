{
  "name": "ice-truck-tracking",
  "version": "2.0.0",
  "description": "Professional Ice Truck Tracking System - Enterprise Monorepo",
  "private": true,
  "scripts": {
    "preinstall": "only-allow pnpm",
    "build": "npx turbo run build",
    "build:all": "turbo run build --force",
    "test": "jest --passWithNoTests",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test:coverage",
    "test:mutation": "npx turbo run test:mutation",
    "test:all": "turbo run test:unit test:integration test:e2e",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "type-check": "tsc --noEmit",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "clean:all": "turbo run clean && rimraf node_modules .turbo backend/node_modules dashboard/node_modules mobile-app/node_modules sdk/edge/node_modules sdk/mobile/node_modules",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans && docker system prune -f",
    "deploy": "pnpm run build && pnpm run docker:build && pnpm run docker:up",
    "deploy:staging": "pnpm run build && docker-compose -f docker-compose.staging.yml up -d",
    "deploy:production": "pnpm run build && docker-compose -f docker-compose.production.yml up -d",
    "security:audit": "pnpm audit --audit-level=high && turbo run security:audit",
    "security:fix": "pnpm audit fix && turbo run security:fix",
    "deps:update": "npx npm-check-updates -u && pnpm install",
    "deps:dedupe": "pnpm dedupe",
    "health:check": "node scripts/health-check.js",
    "setup": "pnpm install && turbo run build && npm run docker:up",
    "prepare": "husky",
    "bootstrap": "pnpm install && turbo run build && turbo run lint && turbo run test",
    "commit": "cz",
    "commitlint": "commitlint --from=HEAD~1",
    "release": "npx semantic-release",
    "security:snyk": "npx snyk test",
    "analyze:frontend": "cd dashboard && pnpm run analyze",
    "snyk:auth": "npx snyk auth"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/node": "^24.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "commitizen": "^4.3.1",
    "conventional-changelog-cli": "^5.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "lucide-react": "^0.576.0",
    "npm-check-updates": "^19.6.3",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "snyk": "^1.1303.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "keywords": [
    "monorepo",
    "ice-truck",
    "tracking",
    "turborepo",
    "enterprise",
    "typescript",
    "react",
    "node.js"
  ],
  "author": "Ice Truck Tracking Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ice-truck-tracking/monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/ice-truck-tracking/monorepo/issues"
  },
  "homepage": "https://github.com/ice-truck-tracking/monorepo#readme",
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/github",
      "@semantic-release/npm"
    ]
  },
  "pnpm": {
    "overrides": {
      "pify": "^6.1.0",
      "axios": "^1.13.5",
      "fast-xml-parser": "^5.5.7",
      "minimatch@<3.1.3": "^3.1.3",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "glob@<10.3.0": "^10.3.0",
      "js-yaml@<4.1.0": "^4.1.0",
      "lodash@<4.17.21": "^4.17.21",
      "qs@<6.11.2": "^6.11.2",
      "semver@<7.5.4": "^7.5.4",
      "tar@<6.2.1": "^6.2.1",
      "tar@>=7.0.0 <7.5.11": "^7.5.11",
      "undici@<5.28.4": "^5.28.4",
      "undici@>=6.0.0 <6.24.0": "^6.24.0",
      "serialize-javascript": "^7.0.3",
      "underscore": "^1.13.8",
      "flatted": "^3.4.2",
      "socket.io-parser": "^4.2.6"
    },
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "@sentry/cli",
      "dtrace-provider",
      "sharp",
      "snyk",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "core-js-pure",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2"
    ]
  }
}
