# Web Application Environment Variables

# API Configuration
# Single authoritative API base (includes version prefix)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
# Backend API base URL for server-side requests (SSR, API routes)
BACKEND_API_BASE_URL=http://localhost:5000/api/v1
# WebSocket URL for real-time telemetry
NEXT_PUBLIC_WS_URL=ws://localhost:5000
# Optional legacy vars (used only if API_BASE_URL is unset)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_API_PREFIX=/api/v1
# WebSocket path used by frontend to connect (backend listens on /ws)
NEXT_PUBLIC_WS_PATH=/ws
NEXT_PUBLIC_REQUEST_ID_HEADER=x-request-id

# Application Settings
NEXT_PUBLIC_APP_NAME=Ice Truck Tracking
NEXT_PUBLIC_APP_VERSION=2.0.0
# Enable client-side telemetry (analytics, error reporting)
NEXT_PUBLIC_ENABLE_TELEMETRY=false

# Map Configuration (TomTom SDK)
NEXT_PUBLIC_TOMTOM_API_KEY=your_tomtom_key_here
# Test/E2E helpers (set to 1 to disable external map SDK during tests)
NEXT_PUBLIC_DISABLE_MAP=0
NEXT_PUBLIC_E2E=0
# Optional: offload clustering to a Web Worker for large datasets
NEXT_PUBLIC_MAP_WORKER=0

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_THREE_HERO=false

# Observability (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Development
NODE_ENV=development
