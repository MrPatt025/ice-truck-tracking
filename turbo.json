{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "type-check", "lint"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.md",
        "!**/__tests__/**",
        "!**/*.spec.*",
        "!**/*.test.*"
      ],
      "outputs": ["dist/**", ".next/**", "build/**", "lib/**", "out/**"],
      "cache": true
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    },
    "clean": {
      "cache": false
    },

    "type-check": {
      "outputs": [],
      "cache": true
    },
    "lint": {
      "outputs": [".eslintcache"],
      "cache": true
    },
    "lint:fix": {
      "outputs": [],
      "cache": false
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "format:check": {
      "outputs": [],
      "cache": true
    },

    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**", "test-results/**", ".nyc_output/**"],
      "cache": true
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**", "test-results/**"],
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["test-results/**", "screenshots/**", "videos/**"],
      "cache": true
    },
    "test:coverage": {
      "dependsOn": ["test:unit", "test:integration"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:mutation": {
      "dependsOn": ["test:unit"],
      "outputs": ["reports/**", "stryker-tmp/**"],
      "cache": true
    },

    "security:audit": {
      "outputs": ["security-reports/**"],
      "cache": false
    },
    "security:fix": {
      "outputs": [],
      "cache": false
    },

    "docker:build": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false
    }
  },

  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "turbo.json",
    ".editorconfig",
    ".gitignore",
    ".prettierrc",
    ".eslintrc.js",
    "eslint.config.mjs",
    "tsconfig.json",
    "commitlint.config.js",
    "lint-staged.config.js",
    "next.config.js"
  ],

  "globalEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "TURBO_TEAM",
    "TURBO_TOKEN",
    "PORT",
    "JWT_SECRET",
    "CLIENT_URL",
    "USE_FAKE_DB",
    "DISABLE_RATE_LIMIT",
    "DATABASE_URL",
    "REDIS_URL",
    "GF_SECURITY_ADMIN_PASSWORD",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WS_URL"
  ],

  "remoteCache": {
    "enabled": true
  }
}
