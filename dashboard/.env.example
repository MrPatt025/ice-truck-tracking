# Web Application Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000

# Application Settings
NEXT_PUBLIC_APP_NAME=Ice Truck Tracking
NEXT_PUBLIC_APP_VERSION=2.0.0

# Map Configuration (TomTom SDK)
NEXT_PUBLIC_TOMTOM_API_KEY=your_tomtom_key_here
# Test/E2E helpers (set to 1 to disable external map SDK during tests)
NEXT_PUBLIC_DISABLE_MAP=0
NEXT_PUBLIC_E2E=0
# Optional: offload clustering to a Web Worker for large datasets
NEXT_PUBLIC_MAP_WORKER=0

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_THREE_HERO=false

# Observability (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Development
NODE_ENV=development
