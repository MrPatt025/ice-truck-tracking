{
  "name": "@ice-truck/backend",
  "version": "2.0.0",
  "description": "Professional Ice Truck Tracking System - Backend API",
  "main": "index.js",
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.writeFileSync('dist/.turbo-build','@ice-truck/backend\\n'); console.log('Backend build complete');\"",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "pnpm exec jest --ci --runInBand --detectOpenHandles --passWithNoTests",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration --runInBand",
    "test:containers": "jest --config ./jest.testcontainers.config.js tests/integration/database.testcontainers.test.js --runInBand --testTimeout=120000",
    "test:watch": "pnpm exec jest --ci --runInBand --passWithNoTests",
    "lint": "eslint . --fix",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "clean": "rm -rf dist coverage",
    "db:migrate": "psql $DATABASE_URL -f database/migrations/001_init.sql",
    "setup": "node src/config/database.js",
    "docker:build": "docker build -t ice-truck-backend .",
    "docker:run": "docker run -p 5000:5000 ice-truck-backend"
  },
  "keywords": [
    "ice-truck",
    "tracking",
    "gps",
    "logistics",
    "api"
  ],
  "author": "Ice Truck Tracking Team",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mqtt": "^5.15.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/jest": "^30.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.4.9"
  }
}
