{
  "name": "@ice-truck/mobile-app",
  "version": "2.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.writeFileSync('dist/.turbo-build','@ice-truck/mobile-app\\n'); console.log('Mobile app build complete');\"",
    "dev": "expo start --non-interactive",
    "start": "expo start",
    "clean": "rm -rf .expo dist",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/drawer": "^7.9.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.11",
    "@sentry/react-native": "^8.9.1",
    "expo": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.14",
    "expo-location": "~55.1.8",
    "expo-network": "~55.0.13",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "react": "19.2.5",
    "react-native": "0.85.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-maps": "^1.27.2",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "~4.24.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/jest-native": "^5.4.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.14",
    "eslint": "^10.2.1",
    "eslint-config-expo": "^55.0.0",
    "jest": "^30.3.0",
    "jest-expo": "~55.0.16",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "private": true
}
